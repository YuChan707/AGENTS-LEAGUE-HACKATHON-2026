# Copy this file to .env and fill in your values
# NEVER commit .env — only commit this .env.example

DATABASE_URL=sqlite+aiosqlite:///./onlooker.db
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
DATABASE_POOL_URL=

# AI / LLM
GROQ_API_KEY=your_groq_api_key_here

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key_here==;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=onlooker-reports

# Azure OpenAI (optional — leave blank to keep using Groq)
# Populated from Key Vault after running containers_env/deploy-mcp.ps1
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure CosmosDB (optional — leave blank to keep SQLite)
# Get connection string from Azure Portal → CosmosDB → Keys
COSMOS_CONNECTION_STRING=

# DevelopFast MCP endpoint (set after deploy-mcp.ps1 completes)
MCP_ENDPOINT=https://func-onlooker-mcp-SUFFIX.azurewebsites.net/api/mcp

# App
MOCK_MODE=false
ENVIRONMENT=development
